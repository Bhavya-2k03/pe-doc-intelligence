# ───────────────────────────────────────────────────────────────────
# Required — app refuses to start without these.
# ───────────────────────────────────────────────────────────────────

# OpenAI (GPT 5.2 extraction + clause interpretation)
OPENAI_API_KEY=sk-proj-...

# LlamaParse (PDF parsing)
LLAMA_CLOUD_API_KEY=llx-...

# Supabase Postgres — use the TRANSACTION pooler URL, not the direct one.
# Format: postgresql://postgres.<ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres....:...@aws-....pooler.supabase.com:6543/postgres

# ───────────────────────────────────────────────────────────────────
# Optional
# ───────────────────────────────────────────────────────────────────

# Write pipeline traces to debug_output/evaluate_trace.txt (local debugging only).
# Leave unset/0 in production — Railway has a read-only filesystem.
# DEBUG_TRACE=1

# Local SQLite fallback path (only used if DATABASE_URL is unset, which the
# startup check now forbids — kept for clarity, not active in normal operation).
# SEED_DB_PATH=db.sqlite
